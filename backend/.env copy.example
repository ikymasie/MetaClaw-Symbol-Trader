# ══════════════════════════════════════════════════════════════════════════════
#  TradeClaw — Backend Environment Configuration
#  Copy this file to .env and fill in your values:  cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Alpaca API (Paper Trading) ────────────────────────────────────────────────
#    Sign up at https://alpaca.markets  →  Paper Trading  →  API Keys
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── AI Brain — Gemini (Cloud LLM) ────────────────────────────────────────────
#    Get a free key at https://aistudio.google.com/apikey
AI_BRAIN_ENABLED=true
AI_ANALYSIS_INTERVAL_MINUTES=60
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite-preview

# ── AI Brain — Ollama (Local LLM Fallback) ────────────────────────────────────
#    Install Ollama: https://ollama.com  →  ollama pull gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=ollama/gemma4:e4b
OLLAMA_MODEL_NAME=gemma4:e4b

# ── Firebase (Fleet Telemetry & Firestore) ────────────────────────────────────
#    Optional — leave blank to run without cloud persistence.
#    Place your service-account-key.json in the project root.
# GOOGLE_APPLICATION_CREDENTIALS=../service-account-key.json

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Trading Defaults ──────────────────────────────────────────────────────────
DEFAULT_SYMBOL=SPY
DEFAULT_QTY=1
MAX_DAILY_DRAWDOWN_PCT=6.0
DEFAULT_STOP_LOSS_PCT=1.0
DEFAULT_BB_PERIOD=20
DEFAULT_BB_STD_DEV=2.0
