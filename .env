MT5_PASSWORD=@J3xuhH#5
MT5_SERVER=Weltrade

# ── News (optional) ───────────────────────────────────────────────────────────
#    Alpaca API key used ONLY for the news REST feed (no trading).
#    Leave blank to disable news-based sentiment analysis.
ALPACA_NEWS_API_KEY=PKETHTNKK5G2CEIUGIAPYLYIMG

# ── AI Brain — Gemini (Cloud LLM) ────────────────────────────────────────────
#    Get a free key at https://aistudio.google.com/apikey
AI_BRAIN_ENABLED=true
AI_ANALYSIS_INTERVAL_MINUTES=60
GEMINI_API_KEY=AIzaSyCUC7G-lR4rgnqh8Bqwo7Rbr8g3ryQ1O7U
GEMINI_MODEL=gemini-2.0-flash-exp
DEEP_THINK_MODEL=gemini-3.1-pro
QUICK_THINK_MODEL=gemini-3.1-flash-preview

# ── AI Brain — Ollama (Local LLM Fallback) ────────────────────────────────────
#    Install Ollama: https://ollama.com  →  ollama pull gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=ollama/gemma4:e4b
OLLAMA_MODEL_NAME=gemma4:e4b

